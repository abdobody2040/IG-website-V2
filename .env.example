# PocketBase (required)
VITE_PB_URL=http://127.0.0.1:8090

# Setup Page (required for dev — passwords, optional emails)
VITE_ADMIN_PASSWORD=your-admin-password
VITE_CLIENT_PASSWORD=your-client-password
VITE_ADMIN_EMAIL=admin@example.com
VITE_CLIENT_EMAIL=client@example.com

# Stripe checkout (optional — needed for payments)
VITE_CHECKOUT_ENDPOINT=https://create-checkout.your-subdomain.workers.dev

# Cloudflare R2 upload (optional — falls back to PocketBase file storage)
VITE_R2_UPLOAD_ENDPOINT=https://upload-validator.your-subdomain.workers.dev

# Email via Resend (optional — emails are skipped if not set)
VITE_EMAIL_ENDPOINT=https://send-email.your-subdomain.workers.dev

# Cloudflare Turnstile CAPTCHA (optional — contact form works without it)
VITE_TURNSTILE_SITE_KEY=

# Contact form Edge Function (optional — enables server-side CAPTCHA verification)
# When set, contact form submits via this endpoint instead of direct database insert
VITE_CONTACT_ENDPOINT=

# User deletion Edge Function (optional — falls back to profile-only deletion)
VITE_DELETE_USER_ENDPOINT=

# Server-side only — set these in Cloudflare Worker secrets or .dev.vars for local development.
# Never expose these with a VITE_ prefix.
STRIPE_SECRET_KEY=sk_test_or_live
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
ALLOWED_ORIGIN=http://localhost:3000
RESEND_API_KEY=re_your-api-key

# ── send-email Worker (Cloudflare Workers env or .dev.vars) ──────────────────
# Set in Cloudflare dashboard → Worker → Settings → Variables
# RESEND_API_KEY=re_your-api-key        (above — shared)
# ALLOWED_ORIGIN=https://instantgrow.net
# PB_URL=https://your-pb-instance.com
# ADMIN_EMAIL=info@instantgrow.net

# ── send-compliance-reminders.mjs (server-side cron only) ───────────────────
# These are only used by the Node.js compliance reminder script (not Vite)
PB_ADMIN_EMAIL=your-admin-email@example.com
PB_ADMIN_PASS=your-admin-password
FROM_EMAIL=noreply@instantgrow.net
APP_URL=https://instantgrow.net
