# Supabase (required)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PocketBase (required)
VITE_PB_URL=http://127.0.0.1:8090

# Setup Page (required for dev — passwords, optional emails)
VITE_ADMIN_PASSWORD=your-admin-password
VITE_CLIENT_PASSWORD=your-client-password
VITE_ADMIN_EMAIL=admin@example.com
VITE_CLIENT_EMAIL=client@example.com

# Stripe checkout (optional — needed for payments)
VITE_CHECKOUT_ENDPOINT=https://your-project.supabase.co/functions/v1/create-checkout

# Cloudflare R2 upload (optional — falls back to Supabase Storage)
VITE_R2_UPLOAD_ENDPOINT=

# Email via Resend (optional — emails are skipped if not set)
VITE_EMAIL_ENDPOINT=

# Cloudflare Turnstile CAPTCHA (optional — contact form works without it)
VITE_TURNSTILE_SITE_KEY=

# Contact form Edge Function (optional — enables server-side CAPTCHA verification)
# When set, contact form submits via this endpoint instead of direct Supabase insert
VITE_CONTACT_ENDPOINT=

# User deletion Edge Function (optional — falls back to profile-only deletion)
VITE_DELETE_USER_ENDPOINT=

# Server-side only — set these in Supabase Edge Function secrets or Worker secrets.
# Never expose these with a VITE_ prefix.
# !! IMPORTANT !! Do NOT add SUPABASE_SERVICE_ROLE_KEY to .env.local
# It must only exist in server-side secret stores (Supabase Edge Function secrets,
# Cloudflare Workers secrets, GitHub Actions secrets, etc.).
# Adding it to .env.local risks committing or bundling it.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STRIPE_SECRET_KEY=sk_test_or_live
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
ALLOWED_ORIGIN=http://localhost:3000
RESEND_API_KEY=re_your-api-key
