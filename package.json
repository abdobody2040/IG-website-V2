{
  "name": "vite-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-og-images.mjs && vite build && node scripts/generate-sitemap.cjs",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.css\" --fix --quiet",
    "lint:js": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:css-vars": "node scripts/check-css-variables.js",
    "check:css-classes": "node scripts/check-css-classes.js",
    "lint": "npm run lint:types && npm run lint:css && npm run check:css-vars",
    "db:setup": "node scripts/setup-db.cjs",
    "db:seed": "node scripts/seed-all.mjs",
    "db:sync-stripe": "node scripts/sync-stripe-prices.mjs",
    "test:e2e": "playwright test"
  },
  "overrides": {
    "brace-expansion": "^5.0.7",
    "fast-uri": "^3.1.3",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260705.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.4.16",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.12",
    "stripe": "^22.3.0",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "3.3.5",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.3",
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-react": "5.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.11",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.0.1",
    "pocketbase": "^0.27.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.72.0",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.7",
    "react-responsive": "^10.0.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  }
}
